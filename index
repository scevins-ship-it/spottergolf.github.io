<nav>
  <a href="/" class="nav-logo">
    <svg class="nav-logo-icon" viewBox="0 0 240 240" xmlns="http://www.w3.org/2000/svg"><use href="#sg-icon"/></svg>
    <div class="nav-logo-text">
      <span class="nav-logo-main">SPOTTER</span>
