</nav>

<!-- HERO -->
<section id="hero">
  <div class="grid-bg"></div>
  <div class="hero-glow"></div>
  <div style="position:relative;z-index:1;">
    <div class="hero-badge">The first AI and LiDAR powered golf ball finder</div>
